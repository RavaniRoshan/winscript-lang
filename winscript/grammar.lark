// WinScript v1 & v2 Grammar
// Language: tell/end tell, set, return, wait, try/catch, repeat, on, declare
// Parser: Lark (Earley)

start: (_NL | statement)*

// ---------------------------------------------------------------------------
// Statements
// ---------------------------------------------------------------------------

?statement: tell_block
          | set_stmt
          | return_stmt
          | wait_stmt
          | try_block
          | if_block
          | command_stmt
          | repeat_block
          | function_def
          | scope_declaration
          | declare_statement
          | using_statement
          | function_call _NL

// ---------------------------------------------------------------------------
// Construct 1 — tell blocks
// ---------------------------------------------------------------------------

tell_block: "tell" app_name ESCAPED_STRING? _NL statement* "end" "tell" _NL

app_name: IDENT ("." IDENT)*

// ---------------------------------------------------------------------------
// Construct 2 — set (variable assignment / property mutation)
// ---------------------------------------------------------------------------

set_stmt: "set" property_access "to" expr _NL   -> set_property
        | "set" IDENT "to" expr _NL              -> set_variable

// ---------------------------------------------------------------------------
// Construct 3 — return
// ---------------------------------------------------------------------------

return_stmt: "return" expr _NL

// ---------------------------------------------------------------------------
// Construct 4 — wait
// ---------------------------------------------------------------------------

wait_stmt: "wait" "until" condition _NL          -> wait_until
         | "wait" NUMBER time_unit _NL           -> wait_duration

time_unit: "seconds"      -> seconds
         | "milliseconds" -> milliseconds

// ---------------------------------------------------------------------------
// Construct 5 — try / catch / end try
// ---------------------------------------------------------------------------

try_block: "try" _NL statement* "catch" IDENT _NL statement* "end" "try" _NL

// ---------------------------------------------------------------------------
// if / then / end if  (single-condition only in v1)
// ---------------------------------------------------------------------------

if_block: "if" condition "then" _NL statement* "end" "if" _NL

// ---------------------------------------------------------------------------
// V2 Constructs
// ---------------------------------------------------------------------------

repeat_block: repeat_times
            | repeat_while
            | repeat_with

repeat_times: "repeat" expr "times" _NL statement* "end" "repeat" _NL

repeat_while: "repeat" "while" condition _NL statement* "end" "repeat" _NL

repeat_with: "repeat" "with" IDENT "in" expr _NL statement* "end" "repeat" _NL

function_def: "on" IDENT "(" param_list? ")" _NL statement* "end" "on" _NL

param_list: IDENT ("," IDENT)*

function_call: IDENT "(" arg_list? ")"

arg_list: expr ("," expr)*

!scope_declaration: ("global" | "local") IDENT _NL

declare_statement: "declare" IDENT "as" type_name _NL

!type_name: "string" | "integer" | "decimal" | "boolean" | "list" | "dict" | "any"

using_statement: "using" ESCAPED_STRING _NL

list_literal: "[" (expr ("," expr)*)? "]"

// ---------------------------------------------------------------------------
// Conditions
// ---------------------------------------------------------------------------

?condition: expr "contains" expr                 -> contains_cond
          | expr "is" "greater" "than" expr      -> gt_cond
          | expr "is" "less" "than" expr         -> lt_cond
          | expr "is" expr                       -> eq_cond
          | expr ">" expr                        -> gt_op_cond
          | expr ">=" expr                       -> gte_op_cond
          | expr "!=" expr                       -> neq_op_cond
          | "loaded"                             -> loaded_cond

// ---------------------------------------------------------------------------
// Commands  (dispatched to current tell scope)
// ---------------------------------------------------------------------------

command_stmt: navigate_cmd _NL
            | click_cmd _NL
            | type_cmd _NL
            | press_cmd _NL
            | screenshot_cmd _NL
            | open_cmd _NL
            | run_script_cmd _NL
            | save_cmd _NL
            | quit_cmd _NL
            | generic_cmd _NL

navigate_cmd:    "navigate" "to" expr
click_cmd:       "click" "element" expr
type_cmd:        "type" expr "into" "element" expr
press_cmd:       "press" expr
screenshot_cmd:  "take" "screenshot"
open_cmd:        "open" expr
run_script_cmd:  "run" "script" expr
save_cmd:        "save"
quit_cmd:        "quit"
generic_cmd:     IDENT (expr)*

// ---------------------------------------------------------------------------
// Property access — "title of active tab"
// ---------------------------------------------------------------------------

property_access: IDENT "of" compound_name

compound_name: IDENT (IDENT | ESCAPED_STRING)*

// ---------------------------------------------------------------------------
// Expressions
// ---------------------------------------------------------------------------

?expr: arith_expr "&" expr                       -> concat
     | arith_expr

?arith_expr: arith_expr "+" term                 -> add
           | arith_expr "-" term                 -> sub
           | term

?term: term "*" atom                             -> mul
     | term "/" atom                             -> div
     | atom

?atom: ESCAPED_STRING                            -> string_lit
     | NUMBER                                    -> number_lit
     | "true"                                    -> true_lit
     | "false"                                   -> false_lit
     | property_access                           -> prop_expr
     | function_call                             -> func_call_expr
     | list_literal                              -> list_expr
     | IDENT                                     -> ident_expr

// ---------------------------------------------------------------------------
// Terminals
// ---------------------------------------------------------------------------

IDENT: /(?!(?:if|tell|set|return|wait|try|catch|end|true|false|of|then|is|contains|loaded|repeat|times|while|with|in|on|global|local|declare|as|string|integer|decimal|boolean|list|dict|any|using)\b)[$a-zA-Z_][a-zA-Z0-9_]*/

// Newline handling — newlines are significant as statement terminators
_NL: NEWLINE+
NEWLINE: /\r?\n/

// Comments start with --
COMMENT: /--[^\n]*/

// Imports from Lark common terminals
%import common.ESCAPED_STRING
%import common.NUMBER

// Ignore horizontal whitespace and comments
%ignore /[ \t]+/
%ignore COMMENT
